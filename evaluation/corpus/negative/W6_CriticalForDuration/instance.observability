<?xml version="1.0" encoding="UTF-8"?>
<!-- Seeded violation: W6 W_CriticalForDuration — CRITICAL alert fires after
     only 30 seconds, well below the recommended minute-scale dwell. -->
<obs:ObservabilityModel xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:obs="http://dissertation.um.edu.my/observability/1.0"
    name="negative-W6" version="1.0.0">
  <services name="S1" namespace="com.example" language="JAVA">
    <instrumentations name="com.example">
      <metrics name="m.errors" type="COUNTER" unit="1" valueType="LONG"/>
    </instrumentations>
  </services>
  <alertRules name="CritShort"
              expression="rate(m_errors[1m]) &gt; 0"
              severity="CRITICAL"
              forDuration="30s"
              referencedMetric="//@services.0/@instrumentations.0/@metrics.0"/>
</obs:ObservabilityModel>
